<%- include('../components/template') %>
<main id="content" class="flex-1 p-6 lg:p-8">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-xl font-semibold text-white"><%= req.translations.overview %></h1>
    <p class="mt-1 text-sm text-zinc-500"><%= req.translations.overviewText %></p>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6 text-cyan-500">
            <path d="M7 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM14.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM1.615 16.428a1.224 1.224 0 0 1-.569-1.175 6.002 6.002 0 0 1 11.908 0c.058.467-.172.92-.57 1.174A9.953 9.953 0 0 1 7 18a9.953 9.953 0 0 1-5.385-1.572ZM14.5 16h-.106c.07-.297.088-.611.048-.933a7.47 7.47 0 0 0-1.588-3.755 4.502 4.502 0 0 1 5.874 2.636.818.818 0 0 1-.36.98A7.465 7.465 0 0 1 14.5 16Z" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-zinc-500"><%= req.translations.users %></p>
          <p class="text-2xl font-semibold text-white"><%= usersTotal %></p>
        </div>
      </div>
    </div>

    <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-6 h-6 text-emerald-500"><rect width="256" height="256" fill="none"/><path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/><path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/><path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/></svg>
        </div>
        <div>
          <p class="text-sm text-zinc-500"><%= req.translations.instances %></p>
          <p class="text-2xl font-semibold text-white"><%= instancesTotal %></p>
        </div>
      </div>
    </div>

    <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-6 h-6 text-amber-500"><rect width="256" height="256" fill="none"/><path d="M208,40H48A16,16,0,0,0,32,56v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40ZM180,92a12,12,0,1,1,12-12A12,12,0,0,1,180,92Z"/><path d="M208,136H48a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V152A16,16,0,0,0,208,136Zm-28,52a12,12,0,1,1,12-12A12,12,0,0,1,180,188Z"/></svg>
        </div>
        <div>
          <p class="text-sm text-zinc-500"><%= req.translations.nodes %></p>
          <p class="text-2xl font-semibold text-white"><%= nodesTotal %></p>
        </div>
      </div>
    </div>

    <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-6 h-6 text-blue-500"><rect width="256" height="256" fill="none"/><path d="M243.31,136,144,36.69A15.86,15.86,0,0,0,132.69,32H40a8,8,0,0,0-8,8v92.69A15.86,15.86,0,0,0,36.69,144L136,243.31a16,16,0,0,0,22.63,0l84.68-84.68a16,16,0,0,0,0-22.63ZM84,96A12,12,0,1,1,96,84,12,12,0,0,1,84,96Z"/></svg>
        </div>
        <div>
          <p class="text-sm text-zinc-500"><%= req.translations.images %></p>
          <p class="text-2xl font-semibold text-white"><%= imagesTotal %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- System Info Card -->
  <div class="bg-[#111113] border border-white/5 rounded-xl p-6 mb-8">
    <script>
      fetch('https://atqr.pages.dev/skyport.json')
        .then(response => response.json())
        .then(data => {
          const currentVersion = '<%= version %>';
          const latestVersion = data.skyport_canary.panel_latest;
          const versionSpan = document.getElementById('currentVersion');
          const versionStatusSpan = document.getElementById('versionStatus');

          versionSpan.textContent = currentVersion;

          if (currentVersion === latestVersion) {
            versionStatusSpan.innerHTML = '<span class="inline-flex items-center gap-1.5 text-emerald-500"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg> <%= req.translations.runningLatestVersion %></span>';
          } else {
            versionStatusSpan.innerHTML = `<span class="text-amber-500"><%= req.translations.newReleaseOjihost1 %> ${latestVersion} <%= req.translations.newReleaseOjihost2 %> <a href="https://github.com/skyport-team/panel/releases/tag/${latestVersion}" class="underline hover:text-amber-400 transition-colors"><%= req.translations.here %></a> <%= req.translations.newReleaseOjihost3 %></span>`;
          }
        })
        .catch(error => {
          console.error('Error fetching latest version:', error);
        });
    </script>
    
    <div class="flex items-start gap-4">
      <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center flex-shrink-0">
        <span class="text-white font-bold text-xl">O</span>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-white">OJIHOST Panel</h3>
        <p class="text-sm text-zinc-500 mt-1">
          <%= req.translations.sysInfoText %> <span id="currentVersion" class="font-mono text-zinc-400"></span>
        </p>
        <p class="text-sm mt-2" id="versionStatus"></p>
      </div>
    </div>
  </div>

  <!-- Quick Links -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <a href="https://discord.gg/kVtDQrrwcc" class="group flex items-center gap-3 bg-[#111113] border border-white/5 rounded-xl p-4 hover:border-amber-500/30 hover:bg-amber-500/5 transition-all duration-200">
      <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center group-hover:bg-amber-500/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-amber-500">
          <path fill-rule="evenodd" d="m7.171 4.146 1.947 2.466a3.514 3.514 0 0 1 1.764 0l1.947-2.466a6.52 6.52 0 0 0-5.658 0Zm8.683 3.025-2.466 1.947c.15.578.15 1.186 0 1.764l2.466 1.947a6.52 6.52 0 0 0 0-5.658Zm-3.025 8.683-1.947-2.466c-.578.15-1.186.15-1.764 0l-1.947 2.466a6.52 6.52 0 0 0 5.658 0ZM4.146 12.83l2.466-1.947a3.514 3.514 0 0 1 0-1.764L4.146 7.171a6.52 6.52 0 0 0 0 5.658ZM5.63 3.297a8.01 8.01 0 0 1 8.738 0 8.031 8.031 0 0 1 2.334 2.334 8.01 8.01 0 0 1 0 8.738 8.033 8.033 0 0 1-2.334 2.334 8.01 8.01 0 0 1-8.738 0 8.032 8.032 0 0 1-2.334-2.334 8.01 8.01 0 0 1 0-8.738A8.03 8.03 0 0 1 5.63 3.297Zm5.198 4.882a2.008 2.008 0 0 0-2.243.407 1.994 1.994 0 0 0-.407 2.243 1.993 1.993 0 0 0 .992.992 2.008 2.008 0 0 0 2.243-.407c.176-.175.31-.374.407-.585a2.008 2.008 0 0 0-.407-2.243 1.993 1.993 0 0 0-.585-.407Z" clip-rule="evenodd" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-white">Discord</p>
        <p class="text-xs text-zinc-500">Community support</p>
      </div>
    </a>

    <a href="https://skyport.dev" class="group flex items-center gap-3 bg-[#111113] border border-white/5 rounded-xl p-4 hover:border-blue-500/30 hover:bg-blue-500/5 transition-all duration-200">
      <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-500/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-blue-500">
          <path d="M10.75 16.82A7.462 7.462 0 0 1 15 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0 0 18 15.06v-11a.75.75 0 0 0-.546-.721A9.006 9.006 0 0 0 15 3a8.963 8.963 0 0 0-4.25 1.065V16.82ZM9.25 4.065A8.963 8.963 0 0 0 5 3c-.85 0-1.673.118-2.454.339A.75.75 0 0 0 2 4.06v11a.75.75 0 0 0 .954.721A7.506 7.506 0 0 1 5 15.5c1.579 0 3.042.487 4.25 1.32V4.065Z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-white">Documentation</p>
        <p class="text-xs text-zinc-500">Learn how to use</p>
      </div>
    </a>

    <a href="https://github.com/skyport-team" class="group flex items-center gap-3 bg-[#111113] border border-white/5 rounded-xl p-4 hover:border-zinc-400/30 hover:bg-zinc-500/5 transition-all duration-200">
      <div class="w-10 h-10 rounded-lg bg-zinc-500/10 flex items-center justify-center group-hover:bg-zinc-500/20 transition-colors">
        <svg class="h-5 w-5 text-zinc-400" viewBox="0 0 1792 1792" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M1664 896q0 251-146.5 451.5t-378.5 277.5q-27 5-39.5-7t-12.5-30v-211q0-97-52-142 57-6 102.5-18t94-39 81-66.5 53-105 20.5-150.5q0-121-79-206 37-91-8-204-28-9-81 11t-92 44l-38 24q-93-26-192-26t-192 26q-16-11-42.5-27t-83.5-38.5-86-13.5q-44 113-7 204-79 85-79 206 0 85 20.5 150t52.5 105 80.5 67 94 39 102.5 18q-40 36-49 103-21 10-45 15t-57 5-65.5-21.5-55.5-62.5q-19-32-48.5-52t-49.5-24l-20-3q-21 0-29 4.5t-5 11.5 9 14 13 12l7 5q22 10 43.5 38t31.5 51l10 23q13 38 44 61.5t67 30 69.5 7 55.5-3.5l23-4q0 38 .5 89t.5 54q0 18-13 30t-40 7q-232-77-378.5-277.5t-146.5-451.5q0-209 103-385.5t279.5-279.5 385.5-103 385.5 103 279.5 279.5 103 385.5z"/></svg>
      </div>
      <div>
        <p class="text-sm font-medium text-white">GitHub</p>
        <p class="text-xs text-zinc-500">View source code</p>
      </div>
    </a>

    <a href="https://github.com/skyport-team" class="group flex items-center gap-3 bg-[#111113] border border-white/5 rounded-xl p-4 hover:border-emerald-500/30 hover:bg-emerald-500/5 transition-all duration-200">
      <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center group-hover:bg-emerald-500/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-emerald-500">
          <path d="M10.75 10.818v2.614A3.13 3.13 0 0 0 11.888 13c.482-.315.612-.648.612-.875 0-.227-.13-.56-.612-.875a3.13 3.13 0 0 0-1.138-.432ZM8.33 8.62c.053.055.115.11.184.164.208.16.46.284.736.363V6.603a2.45 2.45 0 0 0-.35.13c-.14.065-.27.143-.386.233-.377.292-.514.627-.514.909 0 .184.058.39.202.592.037.051.08.102.128.152Z" />
          <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-8-6a.75.75 0 0 1 .75.75v.316a3.78 3.78 0 0 1 1.653.713c.426.33.744.74.925 1.2a.75.75 0 0 1-1.395.55 1.35 1.35 0 0 0-.447-.563 2.187 2.187 0 0 0-.736-.363V9.3c.698.093 1.383.32 1.959.696.787.514 1.29 1.27 1.29 2.13 0 .86-.504 1.616-1.29 2.13-.576.377-1.261.603-1.96.696v.299a.75.75 0 1 1-1.5 0v-.3c-.697-.092-1.382-.318-1.958-.695-.482-.315-.857-.717-1.078-1.188a.75.75 0 1 1 1.359-.636c.08.173.245.376.54.569.313.205.706.353 1.138.432v-2.748a3.782 3.782 0 0 1-1.653-.713C6.9 9.433 6.5 8.681 6.5 7.875c0-.805.4-1.558 1.097-2.096a3.78 3.78 0 0 1 1.653-.713V4.75A.75.75 0 0 1 10 4Z" clip-rule="evenodd" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-white">Support</p>
        <p class="text-xs text-zinc-500">Help the project</p>
      </div>
    </a>
  </div>
</main>
<%- include('../components/footer') %>
