<%- include('../components/template') %>

<main id="content" class="opacity-0 transition-opacity duration-300 p-6">
   <!-- Header -->
   <div class="mb-8">
      <h1 class="text-xl font-semibold text-white"><%= req.translations.overview %></h1>
      <p class="mt-1 text-sm text-zinc-500"><%= req.translations.overviewText %></p>
   </div>

   <!-- Stats Grid -->
   <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-cyan-500/20 transition-all duration-200">
         <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-cyan-500/10 flex items-center justify-center">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-cyan-400">
                  <path d="M4.5 6.375a4.125 4.125 0 1 1 8.25 0 4.125 4.125 0 0 1-8.25 0ZM14.25 8.625a3.375 3.375 0 1 1 6.75 0 3.375 3.375 0 0 1-6.75 0ZM1.5 19.125a7.125 7.125 0 0 1 14.25 0v.003l-.001.119a.75.75 0 0 1-.363.63 13.067 13.067 0 0 1-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 0 1-.364-.63l-.001-.122ZM17.25 19.128l-.001.144a2.25 2.25 0 0 1-.233.96 10.088 10.088 0 0 0 5.06-1.01.75.75 0 0 0 .42-.643 4.875 4.875 0 0 0-6.957-4.611 8.586 8.586 0 0 1 1.71 5.157v.003Z" />
               </svg>
            </div>
            <span class="text-sm font-medium text-zinc-400"><%= req.translations.users %></span>
         </div>
         <p class="text-3xl font-semibold text-white"><%= usersTotal %></p>
      </div>

      <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-emerald-500/20 transition-all duration-200">
         <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-emerald-400">
                  <path d="M12.378 1.602a.75.75 0 0 0-.756 0L3 6.632l9 5.25 9-5.25-8.622-5.03ZM21.75 7.93l-9 5.25v9l8.628-5.032a.75.75 0 0 0 .372-.648V7.93ZM11.25 22.18v-9l-9-5.25v8.57a.75.75 0 0 0 .372.648l8.628 5.033Z" />
               </svg>
            </div>
            <span class="text-sm font-medium text-zinc-400"><%= req.translations.instances %></span>
         </div>
         <p class="text-3xl font-semibold text-white"><%= instancesTotal %></p>
      </div>

      <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-amber-500/20 transition-all duration-200">
         <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-amber-400">
                  <path d="M4.08 5.227A3 3 0 0 1 6.979 3H17.02a3 3 0 0 1 2.9 2.227l2.113 7.926A5.228 5.228 0 0 0 18.75 12H5.25a5.228 5.228 0 0 0-3.284 1.153L4.08 5.227Z" />
                  <path fill-rule="evenodd" d="M5.25 13.5a3.75 3.75 0 1 0 0 7.5h13.5a3.75 3.75 0 1 0 0-7.5H5.25Zm10.5 4.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm3.75-.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" clip-rule="evenodd" />
               </svg>
            </div>
            <span class="text-sm font-medium text-zinc-400"><%= req.translations.nodes %></span>
         </div>
         <p class="text-3xl font-semibold text-white"><%= nodesTotal %></p>
      </div>

      <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-purple-500/20 transition-all duration-200">
         <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-purple-400">
                  <path fill-rule="evenodd" d="M5.25 2.25a3 3 0 0 0-3 3v4.318a3 3 0 0 0 .879 2.121l9.58 9.581c.92.92 2.39 1.186 3.548.428a18.849 18.849 0 0 0 5.441-5.44c.758-1.16.492-2.629-.428-3.548l-9.58-9.581a3 3 0 0 0-2.122-.879H5.25ZM6.375 7.5a1.125 1.125 0 1 0 0-2.25 1.125 1.125 0 0 0 0 2.25Z" clip-rule="evenodd" />
               </svg>
            </div>
            <span class="text-sm font-medium text-zinc-400"><%= req.translations.images %></span>
         </div>
         <p class="text-3xl font-semibold text-white"><%= imagesTotal %></p>
      </div>
   </div>

   <!-- System Info Card -->
   <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-6 mb-6">
      <div class="flex items-start gap-4">
         <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-cyan-600/20 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-cyan-400">
               <path d="M12.378 1.602a.75.75 0 0 0-.756 0L3 6.632l9 5.25 9-5.25-8.622-5.03ZM21.75 7.93l-9 5.25v9l8.628-5.032a.75.75 0 0 0 .372-.648V7.93ZM11.25 22.18v-9l-9-5.25v8.57a.75.75 0 0 0 .372.648l8.628 5.033Z" />
            </svg>
         </div>
         <div class="flex-1">
            <h3 class="text-lg font-semibold text-white mb-1">OJIHOST Panel</h3>
            <p class="text-sm text-zinc-400 mb-3">
               <%= req.translations.sysInfoText %> <span id="currentVersion" class="font-mono text-cyan-400"></span>
            </p>
            <p id="versionStatus" class="text-sm text-zinc-500"></p>
         </div>
      </div>
   </div>

   <script>
      fetch('https://atqr.pages.dev/skyport.json')
         .then(response => response.json())
         .then(data => {
            const currentVersion = '<%= version %>';
            const latestVersion = data.skyport_canary.panel_latest;
            const versionSpan = document.getElementById('currentVersion');
            const versionStatusSpan = document.getElementById('versionStatus');

            versionSpan.textContent = currentVersion;

            if (currentVersion === latestVersion) {
               versionStatusSpan.innerHTML = '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> <%= req.translations.runningLatestVersion %></span>';
            } else {
               versionStatusSpan.innerHTML = `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400"><span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> <%= req.translations.newReleaseOjihost1 %> ${latestVersion} available</span> <a href="https://github.com/skyport-team/panel/releases/tag/${latestVersion}" class="ml-2 text-cyan-400 hover:text-cyan-300 text-sm underline">Update now</a>`;
            }
         })
         .catch(error => {
            console.error('Error fetching latest version:', error);
         });
   </script>

   <!-- Quick Links -->
   <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="https://discord.gg/kVtDQrrwcc" target="_blank" class="group bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-[#5865F2]/30 transition-all duration-200">
         <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-[#5865F2]/10 flex items-center justify-center group-hover:bg-[#5865F2]/20 transition-all duration-200">
               <svg class="w-5 h-5 text-[#5865F2]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
               </svg>
            </div>
            <div>
               <p class="text-sm font-medium text-white group-hover:text-[#5865F2] transition-colors">Discord</p>
               <p class="text-xs text-zinc-500">Community Support</p>
            </div>
         </div>
      </a>

      <a href="https://skyport.dev" target="_blank" class="group bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-blue-500/30 transition-all duration-200">
         <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-500/20 transition-all duration-200">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-blue-400">
                  <path d="M11.25 4.533A9.707 9.707 0 0 0 6 3a9.735 9.735 0 0 0-3.25.555.75.75 0 0 0-.5.707v14.25a.75.75 0 0 0 1 .707A8.237 8.237 0 0 1 6 18.75c1.995 0 3.823.707 5.25 1.886V4.533ZM12.75 20.636A8.214 8.214 0 0 1 18 18.75c.966 0 1.89.166 2.75.47a.75.75 0 0 0 1-.708V4.262a.75.75 0 0 0-.5-.707A9.735 9.735 0 0 0 18 3a9.707 9.707 0 0 0-5.25 1.533v16.103Z" />
               </svg>
            </div>
            <div>
               <p class="text-sm font-medium text-white group-hover:text-blue-400 transition-colors">Documentation</p>
               <p class="text-xs text-zinc-500">Learn how to use</p>
            </div>
         </div>
      </a>

      <a href="https://github.com/skyport-team" target="_blank" class="group bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-zinc-500/30 transition-all duration-200">
         <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-zinc-500/10 flex items-center justify-center group-hover:bg-zinc-500/20 transition-all duration-200">
               <svg class="w-5 h-5 text-zinc-400" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
               </svg>
            </div>
            <div>
               <p class="text-sm font-medium text-white group-hover:text-zinc-300 transition-colors">GitHub</p>
               <p class="text-xs text-zinc-500">Source Code</p>
            </div>
         </div>
      </a>

      <a href="https://github.com/sponsors/skyport-team" target="_blank" class="group bg-[#111111] border border-white/[0.06] rounded-xl p-5 hover:border-pink-500/30 transition-all duration-200">
         <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-pink-500/10 flex items-center justify-center group-hover:bg-pink-500/20 transition-all duration-200">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-pink-400">
                  <path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
               </svg>
            </div>
            <div>
               <p class="text-sm font-medium text-white group-hover:text-pink-400 transition-colors">Sponsor</p>
               <p class="text-xs text-zinc-500">Support Development</p>
            </div>
         </div>
      </a>
   </div>
</main>

<%- include('../components/footer') %>
