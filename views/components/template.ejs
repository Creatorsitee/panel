                        <li>
                           <a href="/admin/auditlogs" searchdata="audit logs admin" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-zinc-400 hover:text-white hover:bg-white/[0.05] transition-all duration-200">
