<!doctype html>
<html class="h-full w-full">
   <head>
      <title><%= name %></title>
      <% if (logo == true) { %>
         <link rel="icon" href="/assets/logo.png" type="image/x-icon">
      <% }  else { %>
         <link rel="icon" href="https://i.imgur.com/uvDunAR.png" type="image/x-icon">
      <% } %>

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <link href="/assets/tailwind.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
   </head>
   <body style="font-family: 'Inter', sans-serif" class="bg-[#0a0a0a] h-full w-full text-white">
      <div>
      <style>
         .sidebar nav ul {
            position: relative;
         }
         .nav-link {
            position: relative;
            z-index: 1;
         }
         .nav-link.active {
            color: #22d3ee;
            font-weight: 500;
            background: rgba(34, 211, 238, 0.08);
         }
         .nav-link:hover:not(.active) {
            background: rgba(255, 255, 255, 0.05);
         }
         @media (max-width: 1024px) {
            .sidebar {
               display: none;
               position: fixed;
               z-index: 50;
               height: 100%;
               width: 280px;
               background-color: #0a0a0a;
               overflow-y: auto;
               transform: translateX(-100%);
               transition: transform 0.3s ease-in-out;
               border-right: 1px solid rgba(255, 255, 255, 0.08);
            }
            .sidebar.open {
               display: block;
               transform: translateX(0);
            }
         }
         .colcont {
            padding-left: 4.5rem !important;
         }
         .colcont-right {
            padding-left: 1rem !important;
            padding-right: 15rem !important;
         }
         .colcontextream {
            padding-right: 15rem !important;
         }
         
         /* Card styles */
         .panel-card {
            background: linear-gradient(135deg, rgba(23, 23, 23, 0.8) 0%, rgba(15, 15, 15, 0.9) 100%);
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.2s ease;
         }
         .panel-card:hover {
            border-color: rgba(34, 211, 238, 0.2);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
         }
         
         /* Accent glow */
         .accent-glow {
            box-shadow: 0 0 30px rgba(34, 211, 238, 0.1);
         }
         
         /* Status badges */
         .status-online {
            background: rgba(34, 197, 94, 0.15);
            color: #22c55e;
         }
         .status-offline {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
         }
         .status-pending {
            background: rgba(234, 179, 8, 0.15);
            color: #eab308;
         }
      </style>

<script>
   document.addEventListener('DOMContentLoaded', () => {
      const loader = document.getElementById('loader');
      const content = document.getElementById('content');

      setTimeout(() => {
         loader.classList.add('opacity-0');
         content.classList.add('opacity-100');
      
         setTimeout(() => {
            loader.style.display = 'none';
         }, 300);
      }, 200);
   });
</script>

<script>
   document.addEventListener('DOMContentLoaded', () => {
      const sidebar = document.getElementById('pc-sidebar');
      const sidebar2 = document.getElementById('pc-sidebar2');
      const colcont = document.getElementById('colcont');

      if ('<%= theme["sidebar-direction"] %>' === 'right') {
         sidebar.classList.add('right-0');
         colcont.classList.add('colcontextream');
         colcont.classList.add('colcont-right');
         sidebar2.classList.remove('border-r');
         sidebar2.classList.add('border-l');
      } else {
         sidebar.classList.add('left-0');
      }
   });
</script>

      <!-- Mobile Toggle Button -->
      <button id="mobile-sidebar-toggle" class="lg:hidden fixed top-4 left-4 z-50 p-2.5 rounded-lg text-zinc-400 border border-white/10 bg-[#0f0f0f] hover:bg-[#171717] hover:text-white transition-all duration-200">
         <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
         </svg>
      </button>

      <!-- Sidebar -->
      <div id="pc-sidebar" class="sidebar transition-all duration-300 ease-in-out hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-60 lg:flex-col group group-[.collapsed]:w-[4.5rem]">
         <div id="pc-sidebar2" class="flex grow flex-col overflow-hidden bg-[#0a0a0a] border-r border-white/[0.06]">
            <nav class="flex flex-1 flex-col">
               <!-- Logo Section -->
               <div class="px-5 py-5 flex items-center border-b border-white/[0.06]">
                  <a href="/" class="flex items-center gap-3">
                     <% if (logo == true) { %>
                     <img src="/assets/logo.png" class="h-8 w-8 rounded-lg">
                     <% } else { %>
                     <div class="h-8 w-8 rounded-lg bg-gradient-to-br from-cyan-400 to-cyan-600 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-white">
                           <path d="M12.378 1.602a.75.75 0 0 0-.756 0L3 6.632l9 5.25 9-5.25-8.622-5.03ZM21.75 7.93l-9 5.25v9l8.628-5.032a.75.75 0 0 0 .372-.648V7.93ZM11.25 22.18v-9l-9-5.25v8.57a.75.75 0 0 0 .372.648l8.628 5.033Z" />
                        </svg>
                     </div>
                     <% } %>
                     <h1 class="text-white font-semibold text-base tracking-tight group-[.collapsed]:hidden"><%= name %></h1>
                  </a>
               </div>

               <!-- User Section -->
               <div class="flex items-center gap-3 px-4 py-4 border-b border-white/[0.06]">
                  <img class="h-9 w-9 rounded-lg ring-2 ring-white/10" src="https://api.dicebear.com/9.x/thumbs/svg?seed=<%= user.username %>&backgroundColor=0a0a0a" alt="User avatar">
                  <div class="group-[.collapsed]:hidden">
                    <p class="text-sm font-medium text-white"><%= user.username %></p>
                    <p class="text-xs text-zinc-500 font-mono"><%= user.userId.substring(0, 8) %></p>
                  </div>
               </div>

               <!-- Navigation -->
               <ul role="list" class="flex flex-1 flex-col px-3 py-4 gap-1">
                  <li>
                     <p class="px-3 mb-2 text-[10px] font-semibold uppercase tracking-wider text-zinc-500 group-[.collapsed]:hidden">Main Menu</p>
                     <ul role="list" class="space-y-1">
                        <li>
                           <a href="/instances" class="nav-link text-zinc-400 px-3 py-2 flex items-center gap-3 rounded-lg text-sm font-medium transition-all duration-200" searchdata="container instances servers">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-[18px] h-[18px]">
                                 <path d="M12.378 1.602a.75.75 0 0 0-.756 0L3 6.632l9 5.25 9-5.25-8.622-5.03ZM21.75 7.93l-9 5.25v9l8.628-5.032a.75.75 0 0 0 .372-.648V7.93ZM11.25 22.18v-9l-9-5.25v8.57a.75.75 0 0 0 .372.648l8.628 5.033Z" />
                              </svg>
                              <span class="group-[.collapsed]:hidden"><%= req.translations.instances %></span>
                           </a>
                        </li>
                        <li>
                           <a href="/account" class="nav-link text-zinc-400 px-3 py-2 flex items-center gap-3 rounded-lg text-sm font-medium transition-all duration-200" searchdata="account profile <%= user.username %>">
