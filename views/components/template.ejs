<!doctype html>
<html class="h-full w-full">
   <head>
      <title><%= name %></title>
      <% if (logo == true) { %>
         <link rel="icon" href="/assets/logo.png" type="image/x-icon">
      <% }  else { %>
         <link rel="icon" href="https://i.imgur.com/uvDunAR.png" type="image/x-icon">
      <% } %>

      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta content="<%= ogTitle %>" property="og:title">
      <meta content="<%= ogDescription %>" property="og:description">
      <link href="/assets/tailwind.css" rel="stylesheet">
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
   </head>
   <body style="font-family: 'Inter', sans-serif" class="bg-[#0a0a0b] h-full w-full text-white antialiased">
      <div class="flex h-full">
      <style>
         .sidebar {
            transition: all 0.3s ease;
         }
         .sidebar nav ul {
            position: relative;
         }
         .nav-link {
            position: relative;
            z-index: 1;
         }
         .nav-link.active {
            background: rgba(6, 182, 212, 0.1);
            color: #06b6d4;
         }
         .nav-link.active svg {
            color: #06b6d4;
         }
         @media (max-width: 1024px) {
            .sidebar {
               display: none;
               position: fixed;
               z-index: 50;
               height: 100%;
               width: 280px;
               background-color: #111113;
               overflow-y: auto;
               transform: translateX(-100%);
               transition: transform 0.3s ease-in-out;
            }
            .sidebar.open {
               display: flex;
               transform: translateX(0);
            }
         }
         
         /* Glow effect for active nav */
         .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 60%;
            background: #06b6d4;
            border-radius: 0 4px 4px 0;
         }

         /* Smooth page transitions */
         #content {
            opacity: 1;
            transform: translateY(0);
            transition: opacity 0.3s ease, transform 0.3s ease;
         }
         
         /* Backdrop blur for mobile overlay */
         .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            z-index: 40;
         }
         .sidebar-overlay.active {
            display: block;
         }
      </style>

      <script>
         document.addEventListener('DOMContentLoaded', () => {
            const loader = document.getElementById('loader');
            const content = document.getElementById('content');

            setTimeout(() => {
               loader.classList.add('opacity-0');
               content.classList.add('opacity-100');
            
               setTimeout(() => {
                  loader.style.display = 'none';
               }, 300);
            }, 200);
         });
      </script>

      <script>
         document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('pc-sidebar');
            const colcont = document.getElementById('colcont');

            if ('<%= theme["sidebar-direction"] %>' === 'right') {
               sidebar.classList.add('right-0');
               colcont.classList.add('lg:pr-64', 'lg:pl-0');
            } else {
               sidebar.classList.add('left-0');
               colcont.classList.add('lg:pl-64');
            }
         });
      </script>

      <!-- Mobile Overlay -->
      <div id="sidebar-overlay" class="sidebar-overlay"></div>

      <!-- Mobile Toggle Button -->
      <button id="mobile-sidebar-toggle" class="lg:hidden fixed top-4 left-4 z-50 p-2.5 rounded-xl text-white border border-white/10 bg-[#111113] hover:bg-[#18181b] active:scale-95 transition-all duration-200 shadow-lg">
         <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
         </svg>
      </button>

      <!-- Sidebar -->
      <div id="pc-sidebar" class="sidebar fixed inset-y-0 z-50 flex w-64 flex-col">
         <div class="flex grow flex-col gap-y-4 overflow-y-auto bg-[#111113] border-r border-white/5 px-4 py-6">
            <!-- Logo Section -->
            <div class="flex items-center gap-3 px-2">
               <% if (logo == true) { %>
               <img src="/assets/logo.png" class="h-8 w-8 rounded-lg">
               <% } else { %>
               <div class="h-8 w-8 rounded-lg bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center">
                  <span class="text-white font-bold text-sm">O</span>
               </div>
               <% } %>
               <h1 class="text-white font-semibold text-lg tracking-tight"><%= name %></h1>
            </div>

            <!-- User Info Section -->
            <div class="flex items-center gap-3 px-3 py-3 rounded-xl bg-white/[0.03] border border-white/5">
               <img class="h-9 w-9 rounded-lg" src="https://api.dicebear.com/9.x/thumbs/svg?seed=<%= user.username %>" alt="User avatar">
               <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-white truncate"><%= user.username %></p>
                  <p class="text-xs text-zinc-500 font-mono"><%= user.userId.substring(0, 8) %></p>
               </div>
            </div>

            <!-- Navigation -->
            <nav class="flex flex-1 flex-col mt-2">
               <ul role="list" class="flex flex-1 flex-col gap-y-1">
                  <!-- Main Navigation -->
                  <li>
                     <p class="px-3 mb-2 text-xs font-medium text-zinc-500 uppercase tracking-wider"><%= req.translations.instances || 'Dashboard' %></p>
                     <ul role="list" class="space-y-1">
                        <li>
                           <a href="/instances" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-zinc-400 hover:text-white hover:bg-white/[0.05] transition-all duration-200" searchdata="container instances servers">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="w-5 h-5 flex-shrink-0"><rect width="256" height="256" fill="none"/><path d="M220,169.09l-92,53.65L36,169.09A8,8,0,0,0,28,182.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,169.09Z"/><path d="M220,121.09l-92,53.65L36,121.09A8,8,0,0,0,28,134.91l96,56a8,8,0,0,0,8.06,0l96-56A8,8,0,1,0,220,121.09Z"/><path d="M28,86.91l96,56a8,8,0,0,0,8.06,0l96-56a8,8,0,0,0,0-13.82l-96-56a8,8,0,0,0-8.06,0l-96,56a8,8,0,0,0,0,13.82Z"/></svg>
                              <span class="text-sm font-medium"><%= req.translations.instances %></span>
                           </a>
                        </li>
                        <li>
                           <a href="/account" searchdata="account profile <%= user.username %>" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-zinc-400 hover:text-white hover:bg-white/[0.05] transition-all duration-200">
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 flex-shrink-0">
                                 <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                              </svg>                                                           
                              <span class="text-sm font-medium"><%= req.translations.account %></span>
                           </a>
                        </li>
                        <% plugins.forEach(plugin => { %>
                           <% if (plugin.sidebar) { %>
                              <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                                 <li>
                                    <a href="<%= value.url %>" searchdata="<%= value.search_data %>" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-zinc-400 hover:text-white hover:bg-white/[0.05] transition-all duration-200">
                                       <% if (value.icon) { %>
                                          <span class="svg-icon w-5 h-5 flex-shrink-0" data-icon-url="<%= value.icon %>"></span>
                                       <% } else { %>
                                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 flex-shrink-0">
                                             <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
                                          </svg>
                                       <% } %>
                                       <span class="text-sm font-medium"><%= key %></span>
                                    </a>
                                 </li>
                              <% }); %>
                           <% } %>
                        <% }); %>
                     </ul>
                  </li>
                  
                  <script>
                     document.addEventListener("DOMContentLoaded", function() {
                        document.querySelectorAll('.svg-icon').forEach(function(span) {
                           const url = span.getAttribute('data-icon-url');
                           fetch(url)
                              .then(response => {
                                 if (!response.ok) throw new Error('Network error');
                                 return response.text();
                              })
                              .then(svgContent => {
                                 span.innerHTML = svgContent;
                              })
                              .catch(error => console.error('SVG Load Error:', error));
                        });
                     });
                  </script>

