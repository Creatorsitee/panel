                              <span class="text-sm font-medium"><%= req.translations.plugins %></span>
                           </a>
                        </li>
                     </ul>
                  </li>
                  <% } %>

                  <!-- Sign Out -->
                  <li class="mt-auto pt-4 border-t border-white/5">
                     <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-zinc-500 hover:text-red-400 hover:bg-red-500/10 transition-all duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 flex-shrink-0">
                           <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
                        </svg>
                        <span class="text-sm font-medium"><%= req.translations.signOut %></span>
                     </a>
                  </li>
               </ul>
            </nav>
         </div>
      </div>

      <!-- Main Content -->
      <div id="colcont" class="flex-1 flex flex-col min-h-screen">
         <!-- Top Header -->
         <header class="sticky top-0 z-40 flex h-16 shrink-0 items-center gap-x-4 bg-[#0a0a0b]/80 backdrop-blur-xl border-b border-white/5 px-4 sm:px-6">
            <!-- Search -->
            <div class="flex flex-1 gap-x-4 self-stretch items-center lg:gap-x-6">
               <div class="relative flex-1 max-w-md ml-12 lg:ml-0">
                  <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white/[0.03] border border-white/5 hover:border-white/10 transition-colors">
                     <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 text-zinc-500">
                        <path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z" clip-rule="evenodd" />
                     </svg>
                     <input id="searchInput" 
                        class="flex-1 bg-transparent text-sm text-white placeholder:text-zinc-500 focus:outline-none" 
                        placeholder="<%= req.translations.search %>" 
                        type="search" 
                        name="search"
                        autocomplete="off"
                        onfocus="showSearchResults()">
                  </div>
                  <div id="searchResults" class="absolute top-full left-0 right-0 mt-2 bg-[#18181b] border border-white/10 rounded-xl shadow-xl hidden overflow-hidden">
                  </div>
               </div>
               <script src="/javascript/search/index.js"></script>

               <!-- Profile Dropdown -->
               <div class="flex items-center gap-x-4">
                  <div class="relative">
                     <button type="button" class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-white/5 transition-colors" id="user-menu-button" onclick="toggleDropdown()">
                        <img class="h-8 w-8 rounded-lg" src="https://api.dicebear.com/9.x/thumbs/svg?seed=<%= user.username %>" alt="">
                        <span class="hidden lg:flex lg:items-center text-sm font-medium text-white">
                           <%= user.username %>
                        </span>
                        <svg class="hidden lg:block h-4 w-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                           <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                     </button>
                     
                     <!-- Dropdown Menu -->
                     <div id="dropdown-menu" class="hidden absolute right-0 z-50 mt-2 w-56 bg-[#18181b] border border-white/10 rounded-xl shadow-xl overflow-hidden transform opacity-0 scale-95 transition-all duration-200">
                        <div class="p-3 border-b border-white/5">
                           <label class="block text-xs font-medium text-zinc-500 mb-2">Language</label>
                           <select id="language-selector" class="w-full bg-[#111113] border border-white/10 rounded-lg py-2 px-3 text-sm text-white focus:outline-none focus:ring-1 focus:ring-cyan-500" onchange="changeLanguage(this.value)">
                              <% languages.forEach(function(language) { %>
                                 <option value="<%= language %>" <%= (req.cookies.lang ? req.cookies.lang : 'en') === language ? 'selected' : '' %>>
                                    <%= req.translations[language] %>
                                 </option>
                              <% }); %>
                           </select>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </header>

         <script>
            function toggleDropdown() {
               const dropdownMenu = document.getElementById('dropdown-menu');
               dropdownMenu.classList.toggle('hidden');
               if (!dropdownMenu.classList.contains('hidden')) {
                  setTimeout(() => {
                     dropdownMenu.style.transform = 'scale(1)';
                     dropdownMenu.style.opacity = '1';
                  }, 10);
               } else {
                  dropdownMenu.style.transform = 'scale(0.95)';
                  dropdownMenu.style.opacity = '0';
               }
            }

            window.addEventListener('click', function(e) {
               const userMenuButton = document.getElementById('user-menu-button');
               const dropdownMenu = document.getElementById('dropdown-menu');
               if (!userMenuButton.contains(e.target) && !dropdownMenu.contains(e.target)) {
                  dropdownMenu.classList.add('hidden');
                  dropdownMenu.style.transform = 'scale(0.95)';
                  dropdownMenu.style.opacity = '0';
               }
            });
         </script>
         <script src="/javascript/language/index.js"></script>

         <script>
            document.addEventListener('DOMContentLoaded', function() {
               const navLinks = document.querySelectorAll('.nav-link');
               const contentSection = document.getElementById('content');
               let isAnimating = false;

               function updateActiveLink(currentPath) {
                  navLinks.forEach((link) => {
                     let currentpathx2 = currentPath.replace('instance/', 'instances');
                     if (currentpathx2.startsWith(link.getAttribute('href'))) {
                        link.classList.add('active');
                     } else {
                        link.classList.remove('active');
                     }
                  });
               }

               updateActiveLink(window.location.pathname);

               function animatePageTransition(href) {
                  if (isAnimating) return;
                  isAnimating = true;

                  contentSection.style.opacity = '0';
                  contentSection.style.transform = 'translateY(10px)';
                  window.location.href = href;
               }

               navLinks.forEach(link => {
                  link.addEventListener('click', (e) => {
                     e.preventDefault();
                     const href = link.getAttribute('href');
                     updateActiveLink(href);
                     animatePageTransition(href);
                  });
               });

               window.addEventListener('popstate', () => {
                  updateActiveLink(window.location.pathname);
               });
            });

            // Mobile sidebar toggle
            document.addEventListener('DOMContentLoaded', () => {
               const sidebar = document.getElementById('pc-sidebar');
               const mobileToggle = document.getElementById('mobile-sidebar-toggle');
               const overlay = document.getElementById('sidebar-overlay');

               if (mobileToggle && sidebar) {
                  mobileToggle.addEventListener('click', () => {
                     sidebar.classList.toggle('open');
                     overlay.classList.toggle('active');
                  });
               }

               if (overlay) {
                  overlay.addEventListener('click', () => {
                     sidebar.classList.remove('open');
                     overlay.classList.remove('active');
                  });
               }
            });
         </script>

         <!-- Loader -->
         <div id="loader" class="fixed inset-0 flex items-center justify-center bg-[#0a0a0b] z-50 transition-opacity duration-300">
            <div class="flex flex-col items-center gap-3">
               <svg class="animate-spin h-8 w-8 text-cyan-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
               </svg>
            </div>
         </div>
