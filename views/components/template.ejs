                                 <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
                              </svg>
                              <span class="group-[.collapsed]:hidden"><%= req.translations.account %></span>
                           </a>
                        </li>
                        
                        <% plugins.forEach(plugin => { %>
                           <% if (plugin.sidebar) { %>
                              <% Object.entries(plugin.sidebar).forEach(([key, value]) => { %>
                                 <li>
                                    <a href="<%= value.url %>" searchdata="<%= value.search_data %>" class="nav-link text-zinc-400 px-3 py-2 flex items-center gap-3 rounded-lg text-sm font-medium transition-all duration-200">
                                       <% if (value.icon) { %>
                                          <span class="svg-icon w-[18px] h-[18px]" data-icon-url="<%= value.icon %>"></span>
                                       <% } else { %>
                                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-[18px] h-[18px]">
                                             <path d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0Z" />
                                          </svg>
                                       <% } %>
                                       <span class="group-[.collapsed]:hidden"><%= key %></span>
                                    </a>
                                 </li>
                              <% }); %>
                           <% } %>
                        <% }); %>
                     </ul>
                  </li>
                  
