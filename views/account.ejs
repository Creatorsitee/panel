<%- include('components/template') %>

<main id="content" class="opacity-0 transition-opacity duration-300 p-6">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-xl font-semibold text-white"><%= req.translations.updateAccount %></h1>
    <p class="mt-1 text-sm text-zinc-500">Manage your account settings and security</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Profile Settings Card -->
    <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-cyan-500/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-cyan-400">
            <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h2 class="text-base font-medium text-white">Profile Information</h2>
          <p class="text-xs text-zinc-500">Update your username and email</p>
        </div>
      </div>

      <form id="change-username-form" action="/change-username" method="POST">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2"><%= req.translations.username %></label>
            <div class="relative">
              <input 
                id="username" 
                type="text" 
                name="username" 
                placeholder="<%= user.username %>"
                class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white placeholder:text-zinc-600 focus:outline-none focus:ring-1 focus:ring-cyan-500/50 focus:border-cyan-500/50 transition-all duration-200 text-sm">
              <span id="username-feedback" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-zinc-500"></span>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2"><%= req.translations.email %></label>
            <input 
              id="email" 
              type="email" 
              name="email" 
              value="<%= user.email %>"
              disabled
              class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-xl text-zinc-500 cursor-not-allowed text-sm">
          </div>

          <button type="submit" id="change-username-btn" disabled class="w-full py-2.5 px-4 bg-cyan-500 hover:bg-cyan-400 disabled:bg-zinc-700 disabled:text-zinc-500 disabled:cursor-not-allowed text-white font-medium rounded-xl transition-all duration-200 text-sm">
            <%= req.translations.updateUsername %>
          </button>
        </div>
      </form>
    </div>

    <!-- Password Settings Card -->
    <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-amber-400">
            <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h2 class="text-base font-medium text-white">Change Password</h2>
          <p class="text-xs text-zinc-500">Update your security credentials</p>
        </div>
      </div>

      <form id="change-password-form" action="/change-password" method="POST">
        <div class="space-y-4">
          <div>
            <div class="flex items-center justify-between mb-2">
              <label class="text-sm font-medium text-zinc-400"><%= req.translations.currentPassword %></label>
              <span id="current-password-feedback" class="text-xs text-zinc-500"></span>
            </div>
            <input 
              id="currentPassword" 
              type="password" 
              name="currentPassword"
              placeholder="<%= req.translations.currentPasswordHide %>"
              class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white placeholder:text-zinc-600 focus:outline-none focus:ring-1 focus:ring-cyan-500/50 focus:border-cyan-500/50 transition-all duration-200 text-sm">
          </div>

          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2"><%= req.translations.newPassword %></label>
            <input 
              id="newPassword" 
              type="password" 
              name="newPassword"
              placeholder="<%= req.translations.newPasswordHide %>"
              disabled
              class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white placeholder:text-zinc-600 focus:outline-none focus:ring-1 focus:ring-cyan-500/50 focus:border-cyan-500/50 disabled:bg-white/[0.02] disabled:text-zinc-600 disabled:cursor-not-allowed transition-all duration-200 text-sm">
          </div>

          <button type="submit" class="w-full py-2.5 px-4 bg-amber-500 hover:bg-amber-400 disabled:bg-zinc-700 disabled:text-zinc-500 disabled:cursor-not-allowed text-white font-medium rounded-xl transition-all duration-200 text-sm">
            <%= req.translations.update_password %>
          </button>
        </div>
      </form>
    </div>

    <!-- Two-Factor Authentication Card -->
    <div class="bg-[#111111] border border-white/[0.06] rounded-xl p-6 lg:col-span-2">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-emerald-400">
              <path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 0 0-1.032 0 11.209 11.209 0 0 1-7.877 3.08.75.75 0 0 0-.722.515A12.74 12.74 0 0 0 2.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 0 0 .374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 0 0-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08Zm3.094 8.016a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <h2 class="text-base font-medium text-white">Two-Factor Authentication</h2>
            <p class="text-xs text-zinc-500">Add an extra layer of security to your account</p>
          </div>
        </div>
        
        <% if (user.twoFAEnabled !== true) { %>
          <button onclick="window.location.href = '/enable-2fa';" class="px-4 py-2 bg-emerald-500 hover:bg-emerald-400 text-white font-medium rounded-xl transition-all duration-200 text-sm">
            <%= req.translations.enabled2FA %>
          </button>
        <% } else { %>
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              Enabled
            </span>
            <form action="/disable-2fa" method="POST" class="inline">
              <button type="submit" class="px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 font-medium rounded-xl transition-all duration-200 text-sm border border-red-500/20">
                <%= req.translations.disable2FA %>
              </button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const currentPasswordInput = document.getElementById('currentPassword');
  const newPasswordInput = document.getElementById('newPassword');
  const currentPasswordFeedback = document.getElementById('current-password-feedback');
  let currentPasswordTimeoutId;
  let controller;

  currentPasswordInput.addEventListener('input', async () => {
    clearTimeout(currentPasswordTimeoutId);
    newPasswordInput.disabled = true;
    newPasswordInput.value = '';

    if (controller) controller.abort();
    controller = new AbortController();

    const currentPassword = currentPasswordInput.value.trim();
    if (currentPassword === '') {
      currentPasswordFeedback.textContent = '';
      return;
    }

    currentPasswordFeedback.innerHTML = '<svg class="animate-spin h-3 w-3 inline mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Checking...';

    currentPasswordTimeoutId = setTimeout(async () => {
      try {
        const response = await fetch('/validate-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ currentPassword }),
          signal: controller.signal
        });

        if (response.ok) {
          const data = await response.json();
          if (data.valid) {
            currentPasswordFeedback.innerHTML = '<span class="text-emerald-400"><%= req.translations.correctPassword %></span>';
            newPasswordInput.disabled = false;
          } else {
            currentPasswordFeedback.innerHTML = '<span class="text-red-400"><%= req.translations.incorrectPassword %></span>';
          }
        }
      } catch (error) {
        if (error.name !== 'AbortError') {
          currentPasswordFeedback.innerHTML = '<span class="text-red-400">Error</span>';
        }
      }
    }, 500);
  });
});

document.addEventListener('DOMContentLoaded', () => {
  const usernameInput = document.getElementById('username');
  const changeUsernameBtn = document.getElementById('change-username-btn');
  const usernameFeedback = document.getElementById('username-feedback');
  let timeoutId;

  async function checkUsername() {
    const username = usernameInput.value.trim().toLowerCase();

    if (username === '') {
      usernameFeedback.textContent = '';
      changeUsernameBtn.disabled = true;
      return;
    }

    usernameFeedback.innerHTML = '<svg class="animate-spin h-3 w-3 inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';

    clearTimeout(timeoutId);
    timeoutId = setTimeout(async () => {
      const response = await fetch(`/check-username?username=${encodeURIComponent(username)}`);
      const data = await response.json();

      if (data.exists) {
        usernameFeedback.innerHTML = '<span class="text-red-400"><%= req.translations.usernameTaken %></span>';
        changeUsernameBtn.disabled = true;
      } else {
        usernameFeedback.innerHTML = '<span class="text-emerald-400"><%= req.translations.usernameIsNotTaken %></span>';
        changeUsernameBtn.disabled = false;
      }
    }, 500);
  }

  usernameInput.addEventListener('input', () => {
    clearTimeout(timeoutId);
    timeoutId = setTimeout(checkUsername, 500);
  });

  document.getElementById('change-username-form').addEventListener('submit', async (event) => {
    event.preventDefault();
    const currentUsername = '<%= user.username %>';
    const newUsername = usernameInput.value.trim();

    try {
      const response = await fetch('/update-username', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentUsername, newUsername })
      });

      if (response.ok) {
        alert('<%= req.translations.usernameUpdatedSuccess %>');
        window.location.href = '/login?err=UpdatedCredentials';
      } else {
        const errorMessage = await response.text();
        alert(errorMessage);
      }
    } catch (error) {
      alert('<%= req.translations.updatingUsernameError %>');
    }
  });
});
</script>

<%- include('components/footer') %>
