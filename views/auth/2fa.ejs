<!DOCTYPE html>
<html class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= name %> - Two-Factor Authentication</title>
  <link href="../assets/tailwind.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body style="font-family: 'Inter', sans-serif" class="bg-[#0a0a0b] h-full antialiased">
<div class="min-h-full flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md">
    <!-- Card -->
    <div class="bg-[#111113] border border-white/10 rounded-2xl p-8 shadow-xl">
      <!-- Header -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center shadow-lg shadow-cyan-500/25">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-white">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
        </div>
        <h1 class="text-xl font-semibold text-white">Two-Factor Authentication</h1>
        <p class="mt-2 text-sm text-zinc-500">
          Enter the 6-digit code from your authenticator app
        </p>
      </div>

      <!-- Form -->
      <form action="/2fa" method="POST" class="space-y-6">
        <div>
          <label for="token" class="block text-sm font-medium text-zinc-400 mb-2">Verification Code</label>
          <input 
            type="text" 
            id="token" 
            name="token" 
            placeholder="000000"
            maxlength="6"
            pattern="[0-9]{6}"
            inputmode="numeric"
            autocomplete="one-time-code"
            required 
            class="w-full px-4 py-3 bg-[#0a0a0b] border border-white/10 rounded-xl text-white text-center text-2xl tracking-[0.5em] font-mono placeholder-zinc-700 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all duration-200">
        </div>

        <button 
          type="submit" 
          class="w-full py-3 px-4 bg-cyan-500 hover:bg-cyan-400 text-[#0a0a0b] font-medium rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-cyan-500/25 active:scale-[0.98] text-sm">
          Verify
        </button>

        <% if (req.query.err && req.query.err == "InvalidAuthCode") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <span class="text-amber-500 text-sm">Invalid authentication code. Please try again.</span>
        </div>
        <% } %>
      </form>

      <p class="mt-6 text-center text-xs text-zinc-600">
        Having trouble? Contact support for assistance.
      </p>
    </div>
  </div>
</div>
</body>
</html>
