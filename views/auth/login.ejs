<!DOCTYPE html>
<html class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= name %> - Login</title>
  <link href="../assets/tailwind.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body style="font-family: 'Inter', sans-serif" class="bg-[#0a0a0b] h-full antialiased">
<div class="min-h-full flex">
  <!-- Left Side - Form -->
  <div class="flex-1 flex flex-col justify-center py-12 px-4 sm:px-6 lg:flex-none lg:px-20 xl:px-24">
    <div class="mx-auto w-full max-w-sm lg:w-96">
      <!-- Header -->
      <div class="mb-10">
        <% if (logo == true) { %>
        <div class="flex items-center gap-3 mb-8">
          <img class="h-10 w-10 rounded-xl" src="../assets/logo.png" alt="Logo">
          <span class="text-white font-semibold text-xl"><%= name %></span>
        </div>
        <% } else { %>
        <div class="flex items-center gap-3 mb-8">
          <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center">
            <span class="text-white font-bold text-lg">O</span>
          </div>
          <span class="text-white font-semibold text-xl"><%= name %></span>
        </div>
        <% } %>
        <h1 class="text-2xl font-semibold text-white">Welcome back</h1>
        <p class="mt-2 text-sm text-zinc-500">
          Enter your credentials to access your account
        </p>
      </div>

      <!-- Form -->
      <form id="login-form" class="space-y-5" onsubmit="event.preventDefault(); submitForm();">
        <div>
          <label for="username" class="block text-sm font-medium text-zinc-400 mb-2">Username or Email</label>
          <input 
            placeholder="Enter your username or email" 
            id="username" 
            autocomplete="username" 
            required 
            class="w-full px-4 py-3 bg-[#111113] border border-white/10 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all duration-200 text-sm">
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-zinc-400 mb-2">Password</label>
          <input 
            placeholder="Enter your password" 
            id="password" 
            name="password" 
            type="password" 
            autocomplete="current-password" 
            required 
            class="w-full px-4 py-3 bg-[#111113] border border-white/10 rounded-xl text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all duration-200 text-sm">
        </div>

        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <input 
              id="remember-me" 
              name="remember-me" 
              type="checkbox" 
              class="h-4 w-4 rounded bg-[#111113] border-white/20 text-cyan-500 focus:ring-cyan-500 focus:ring-offset-0">
            <label for="remember-me" class="ml-2 text-sm text-zinc-500">Remember me</label>
          </div>
          <a href="/auth/reset-password" class="text-sm text-zinc-500 hover:text-cyan-400 transition-colors">Forgot password?</a>
        </div>

        <button 
          type="submit" 
          onclick="submitForm()" 
          class="w-full py-3 px-4 bg-cyan-500 hover:bg-cyan-400 text-[#0a0a0b] font-medium rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-cyan-500/25 active:scale-[0.98] text-sm">
          Sign in
        </button>
        
        <% if (settings.register) { %>
        <p class="text-center text-sm text-zinc-500 pt-2">
          Don't have an account? 
          <a href="/register" class="text-cyan-400 hover:text-cyan-300 font-medium transition-colors">Create one</a>
        </p>
        <% } %>
      </form>

      <!-- Error/Success Messages -->
      <div class="mt-6 space-y-3">
        <% if (req.query.err && req.query.err == "InvalidCredentials") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <span class="text-amber-500 text-sm">Invalid credentials. Please try again.</span>
        </div>
        <% } %>

        <% if (req.query.err && req.query.err == "UpdatedCredentials") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-emerald-500 text-sm">Your account has been updated. Please enter your new credentials.</span>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg == "EmailVerified") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-emerald-500 text-sm">Your account has been verified. You can login now.</span>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg == "InvalidVerificationToken") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <span class="text-amber-500 text-sm">Your verification link is invalid or expired. Please try again.</span>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg == "VerificationEmailResent") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-emerald-500 text-sm">Verification link resent successfully. Check your email.</span>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg == "UserNotFound") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <span class="text-amber-500 text-sm">User not found. Please try again.</span>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg == "UserAlreadyVerified") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <span class="text-amber-500 text-sm">Your account is already verified. You may sign in.</span>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg == "AccountcreateEmailSent") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-emerald-500 text-sm">Account created successfully. Please check your email to continue.</span>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg == "AccountCreated") { %>
        <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-emerald-500 text-sm">Account created successfully. You may sign in now.</span>
        </div>
        <% } %>

        <% if (req.query.err && req.query.err === "UserNotVerified") { %>
        <div class="flex items-start gap-2 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/20">
          <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <p class="text-red-500 text-sm">Your account isn't verified. Please check your email. <a href="/resend-verification" class="text-red-300 hover:text-red-200 underline transition-colors">Resend Email</a></p>
        </div>
        <% } %>

        <% if (req.query.msg && req.query.msg === 'PasswordReset') { %>
          <% if (req.query.state && req.query.state === 'success') { %>
          <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20">
            <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span class="text-emerald-500 text-sm">Your password has been successfully updated.</span>
          </div>
          <% } else if (req.query.state && req.query.state === 'failed') { %>
          <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/20">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
            <span class="text-red-500 text-sm">Password reset failed. Please try again.</span>
          </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right Side - Visual -->
  <div class="hidden lg:flex relative w-0 flex-1 bg-[#111113]">
    <div class="absolute inset-0 flex items-center justify-center p-12">
      <div class="max-w-lg text-center">
        <div class="w-20 h-20 mx-auto mb-8 rounded-2xl bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center shadow-lg shadow-cyan-500/25">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-white">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
          </svg>
        </div>
        <h2 class="text-3xl font-semibold text-white mb-4">Game Server Management</h2>
        <p class="text-zinc-500 text-lg leading-relaxed">Deploy, manage, and scale your game servers with ease. Full control at your fingertips.</p>
        
        <div class="mt-12 grid grid-cols-3 gap-8">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">99.9%</div>
            <div class="text-sm text-zinc-500 mt-1">Uptime</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-white">50ms</div>
            <div class="text-sm text-zinc-500 mt-1">Avg Latency</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-white">24/7</div>
            <div class="text-sm text-zinc-500 mt-1">Support</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Decorative elements -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
  </div>
</div>

<script>
  document.getElementById('login-form').addEventListener('keypress', function(event) {
    if (event.key === 'Enter') {
      event.preventDefault();
      let username = document.getElementById("username").value.trim();
      let password = document.getElementById("password").value.trim();

      if (username !== "" && password === "") {
        document.getElementById("password").focus();
      } else {
        submitForm();
      }
    }
  });

  async function submitForm() {
    let username = document.getElementById("username").value.trim();
    let password = document.getElementById("password").value.trim();
    
    if (username === "" || password === "") {
      document.location.href = `/auth/login?err=InvalidCredentials&state=failed`;
      return;
    }
    
    let encodedUsername = encodeURIComponent(username);
    let encodedPassword = encodeURIComponent(password);
    
    document.location.href = `/auth/login?username=${encodedUsername}&password=${encodedPassword}`;
  }
</script>
</body>
</html>
